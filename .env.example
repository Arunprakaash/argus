# ──────────────────────────────────────────────────────────────────────────
# Supabase
# ──────────────────────────────────────────────────────────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
# Service-role / secret key (sb_secret_...) — server-side only, bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=

# Public (browser) values for Supabase Auth. The anon/publishable key is safe to ship.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Direct/pooler Postgres connection string (used only by scripts/apply-migrations.mjs).
DATABASE_URL=

# Supabase Storage (S3-compatible) — LiveKit Egress writes recordings here.
SUPABASE_S3_ENDPOINT=https://<project-ref>.storage.supabase.co/storage/v1/s3
SUPABASE_S3_REGION=us-east-1
SUPABASE_S3_ACCESS_KEY=
SUPABASE_S3_SECRET_KEY=
RECORDINGS_BUCKET=recordings

# ──────────────────────────────────────────────────────────────────────────
# Ingestion auth — shared secret the agent observer SDK presents.
# ──────────────────────────────────────────────────────────────────────────
INGEST_API_KEY=

# ──────────────────────────────────────────────────────────────────────────
# LiveKit (for webhook verification + egress control)
# ──────────────────────────────────────────────────────────────────────────
LIVEKIT_URL=wss://<your-livekit-host>
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ──────────────────────────────────────────────────────────────────────────
# OpenAI (analysis engine)
# ──────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
ANALYSIS_MODEL=gpt-4o-mini
ANALYSIS_MODEL_HARD=gpt-4o
